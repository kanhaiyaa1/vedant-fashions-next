# ─── Site ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.vedantfashion.com

# ─── Email / Contact Form ────────────────────────────────────────────────────
# Resend (https://resend.com) — used by /api/contact to send inquiry emails
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CONTACT_EMAIL_TO=info@vedantfashion.com

# Alternative: SendGrid
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Analytics (optional) ───────────────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Images ─────────────────────────────────────────────────────────────────
# Place og-default.jpg (1200×630 px) in /public before deploying.
# This image is referenced in src/app/layout.tsx openGraph metadata.
